# RegiTrackr staging environment variables
# Do not commit real secrets. Values below are placeholders/documentation only.

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Runtime app connection (Supabase transaction pooler, recommended 6543).
# Format:
# postgresql://<user>:<password>@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require&uselibpqcompat=true
DATABASE_URL=""

# Migration/admin connection (direct/session connection, typically 5432).
# Format:
# postgresql://<user>:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require&uselibpqcompat=true
DIRECT_URL=""

# -----------------------------------------------------------------------------
# Clerk
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=""

# -----------------------------------------------------------------------------
# Upstash Redis
# -----------------------------------------------------------------------------
# Format: https://<name>.upstash.io
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# -----------------------------------------------------------------------------
# Inngest
# -----------------------------------------------------------------------------
INNGEST_SIGNING_KEY=""
INNGEST_EVENT_KEY=""

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
RESEND_API_KEY=""

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
# Format: https://<public>@o<org>.ingest.<region>.sentry.io/<project-id>
SENTRY_DSN=""

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# -----------------------------------------------------------------------------
# Encryption + portal auth
# -----------------------------------------------------------------------------
# 32-byte hex string (64 hex chars)
ENCRYPTION_KEY=""

# Random high-entropy secret for portal JWT signing
PORTAL_JWT_SECRET=""

# -----------------------------------------------------------------------------
# App URL
# -----------------------------------------------------------------------------
# Staging URL example: https://regitrackr-staging.vercel.app
# Production URL example: https://app.regitrackr.com
NEXT_PUBLIC_APP_URL=""

# -----------------------------------------------------------------------------
# Staging vs production notes
# -----------------------------------------------------------------------------
# These usually differ between staging and production:
# - DATABASE_URL
# - DIRECT_URL
# - NEXT_PUBLIC_APP_URL
# - CLERK_* keys/secrets
# - STRIPE_* keys/secrets/webhook secret
# - SENTRY_DSN
# - INNGEST_SIGNING_KEY / INNGEST_EVENT_KEY
# - RESEND_API_KEY
